rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Publicly readable animal listings.
    match /artifacts/{appId}/public/data/animals/{animalId} {
      allow read: if request.auth != null;

      // TEMPORARY prototype rules:
      // Anyone authenticated can create/delete animals.
      // Replace this with real admin authorization before public production use.
      allow create, delete: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Adoption applications.
    match /artifacts/{appId}/public/data/requests/{requestId} {
      allow create: if request.auth != null;
      allow read, delete: if request.auth != null;
      allow update: if request.auth != null;
    }

    // User profiles.
    match /artifacts/{appId}/public/data/users/{userId} {
      allow read, write: if request.auth != null
                          && request.auth.uid == userId;
    }
  }
}
